# --- PRODUCTION ENVIRONMENT TEMPLATE ---
# Copy these into your Railway/Render/Cloud provider's dashboard.
# DO NOT include this file in your GitHub repository.

# Database (From Railway/Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# Security
JWT_SECRET="generate-a-very-long-random-string-here"
NODE_ENV="production"

# Networking
PORT=3001
FRONTEND_URL="https://your-marketverse-frontend.vercel.app"

# Redis (For WebSockets - From Railway/Upstash)
REDIS_URL="redis://default:PASSWORD@HOST:PORT"
REDIS_HOST="your-redis-host"
REDIS_PORT=6379
REDIS_PASSWORD="your-redis-password"

# Optional: Cloudinary/S3 for actual images
# CLOUDINARY_URL=...
